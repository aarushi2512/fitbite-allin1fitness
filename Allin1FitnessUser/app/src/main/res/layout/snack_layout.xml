<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/view_bg">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/snackitem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item Name"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/snackitemprotein"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Protein"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:drawableStart="@drawable/ic_protein"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical"/>

                <TextView
                    android:id="@+id/snackitemcarbs"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Carbs"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:drawableStart="@drawable/ic_carbs"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical"/>

                <TextView
                    android:id="@+id/snackitemfats"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Fats"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:drawableStart="@drawable/ic_fats"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical"/>
            </LinearLayout>

            <TextView
                android:id="@+id/snackitemcat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
